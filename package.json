{
  "name": "kalend-ai",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=frontend & npm run dev --workspace=backend",
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "ci": "npm run prisma:generate --workspace=backend && npm run build --workspaces",
    "start": "node backend/dist/server.js"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "better-sqlite3": "^12.10.0",
    "node-fetch": "^3.3.2",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "sqlite3": "^6.0.1"
  }
}
