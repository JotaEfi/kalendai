# Banco de Dados
# Parâmetros de pool: connection_limit=10 (máx conexões), pool_timeout=10s, connect_timeout=10s
DATABASE_URL=postgresql://kalend_user:kalend_pass@postgres:5432/kalend_ai?sslmode=disable&connection_limit=10&pool_timeout=10&connect_timeout=10

# JWT
JWT_SECRET=troque_este_jwt_secret_em_producao
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=troque_este_refresh_secret_em_producao
REFRESH_TOKEN_EXPIRES_IN=7d

# Administrador inicial (seeder)
ADMIN_EMAIL=admin@kalend.ai
ADMIN_PASSWORD=troque-esta-senha-admin
ADMIN_NAME=Administrador

# MinIO / S3
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=troque_esta_access_key
MINIO_SECRET_KEY=troque_esta_secret_key
MINIO_BUCKET_NAME=kalend-ai-images
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# IA: configure apenas um provedor ativo aqui
AI_PROVIDER=deepseek
AI_API_KEY=troque_esta_chave
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com

# App
PORT=3001
NODE_ENV=production
FRONTEND_URL=http://localhost

# ─── Rollover de Cards ─────────────────────────────────
# Fuso horário IANA usado para calcular a meia-noite do rollover.
# O rollover acontece às 23:59 neste fuso horário.
#
# Exemplos de fusos válidos:
#   America/Sao_Paulo    → Brasil (BRT, UTC-3)
#   America/New_York     → EUA Leste (EST/EDT, UTC-4/-5)
#   America/Los_Angeles  → EUA Oeste (PST/PDT, UTC-7/-8)
#   America/Buenos_Aires → Argentina (ART, UTC-3)
#   Europe/Lisbon        → Portugal (WET/WEST, UTC+0/+1)
#   Europe/London        → Reino Unido (GMT/BST)
#   Europe/Berlin        → Alemanha (CET/CEST, UTC+1/+2)
#   Asia/Tokyo           → Japão (JST, UTC+9)
#   UTC                  → Universal (sem ajuste de horário)
TIMEZONE=America/Sao_Paulo

# Se true, cards não serão rolados para sábado ou domingo.
# Na sexta-feira, serão transportados diretamente para segunda-feira.
# Valor padrão: false (fins de semana habilitados)
DISABLE_WEEKENDS=false

# Limites dinamicos de anexos por cartao
MAX_ATTACHMENTS_PER_CARD=3
MAX_ATTACHMENT_SIZE_MB=20

# SMTP (convites por e-mail)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=KalendAI <noreply@kalend.ai>
SMTP_SECURE=false
